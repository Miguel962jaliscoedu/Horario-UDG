# =============================================================================
# VARIABLES DE ENTORNO — Horario-UDG
# =============================================================================
# Copia este archivo como .env y completa los valores.
#    cp .env.example .env
#
# Las variables VITE_* son públicas (van al frontend).
# Las demás son sólo para el backend (API serverless).
# =============================================================================

# ─── Firebase Web SDK (público) ─────────────────────────────────────────────
# Se obtienen de: Firebase Console → Project Settings → General → Web Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google OAuth ───────────────────────────────────────────────────────────
# Se obtiene de: Google Cloud Console → APIs & Services → Credentials
# Es el "Client ID" de una credencial tipo "Web application"
VITE_GOOGLE_CLIENT_ID=
# Opcional — dominio restringido para iniciar sesión (ej: gdl.cutonala.udg.mx)
VITE_GOOGLE_HOSTED_DOMAIN=

# ─── VAPID Key (Notificaciones Push) ────────────────────────────────────────
# Se genera en: Firebase Console → Project Settings → Cloud Messaging
# → "Web Push certificates" → "Generate Key"
# Luego también se registra en el service worker (firebase-messaging-sw.js)
VITE_FIREBASE_VAPID_KEY=

# ─── Firebase Admin SDK (backend) ────────────────────────────────────────────
# La credencial de servicio en formato JSON directo (o base64).
# Pasos para obtenerla:
#   1. Firebase Console → Project Settings → Service Accounts → Generate Key
#   2. Abrir el JSON descargado y pegar TODO el contenido AQUÍ
#      (Opcional — también acepta base64 si lo prefieres)
FIREBASE_ADMIN_CREDENTIALS=

# ID del proyecto Firebase (opcional — se auto-detecta desde las credenciales)
FIREBASE_PROJECT_ID=

# ─── CRON Secret ────────────────────────────────────────────────────────────
# Secreto para proteger el endpoint de monitoreo (/api/monitorear-cupos).
# Debe ser una cadena aleatoria segura (ej: 64 caracteres hex).
# En producción, Vercel añade automáticamente el header:
#   Authorization: Bearer <CRON_SECRET>
# En local puedes omitirlo, o pasarlo manual en el header.
CRON_SECRET=
